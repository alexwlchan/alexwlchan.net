{% extends "rss_feed.xml" %}

{% block content %}
  <link href="https://alexwlchan.net/notes/atom.xml" rel="self" type="application/atom+xml" />
  <link href="{{ '/notes/' | absolute_url }}" rel="alternate" type="text/html" />
  <id>{{ '/' | absolute_url | xml_escape }}</id>
  <title type="html">{{ "alexwlchan’s notes" | xml_escape }}</title>
  <subtitle>{{ "Alex Chan’s Notes" | xml_escape }}</subtitle>

  {% for post in notes[:25] %}
    {% include "partials/rss_feed_entry.xml" %}
  {% endfor %}
{% endblock %}
