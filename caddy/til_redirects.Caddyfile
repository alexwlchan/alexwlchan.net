# In January 2025, I moved all my Today I Learned (TILs) from
# a separate subdomain (til.alexwlchan.net) to a path on the main site.
#
# Because the two sites run on the same web server, this Caddy config
# creates the redirects, so I can shut down the old site.
#
# The file `til_redirects.json` is new slug/old paths.
#
# To rebuild this file:
#
#     uv pip install cogapp
#     cog -c r caddy/til_redirects.Caddyfile
#
til.alexwlchan.net {
  #[[[cog
  # import cog
  # import json
  # 
  # with open("caddy/til_redirects.json") as in_file:
  #     redirects = json.load(in_file)
