  # for new_slug, all_old_paths in redirects.items():
  #     for old_path in all_old_paths:
  #         cog.outl(f"redir {old_path} https://alexwlchan.net{new_slug} permanent")
  # 
  #]]]
  redir / https://alexwlchan.net/til/ permanent
  redir /atom.xml https://alexwlchan.net/til/atom.xml permanent
